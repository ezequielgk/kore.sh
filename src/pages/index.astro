---
import Layout from '../layouts/Layout.astro';
import packages from '../data/packages.json';
import categories from '../data/categories.json';
---

<Layout title="Kore">

  <!-- HERO -->
  <section class="py-16 px-4 text-center">
    <div class="flex flex-col items-center justify-center max-w-2xl mx-auto">
      <img src="/icon/kore-logo.svg" alt="KPM" width="56" height="56" class="mb-6" />
      <h1 class="text-4xl font-semibold mb-4 text-[var(--text-primary)]">Kore</h1>
      <p class="text-lg text-[var(--text-secondary)] mb-8">Install any Linux app with one command.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center w-full">
        <a href="/browse" class="px-6 py-2 font-medium text-[#0a0a0a] bg-[var(--accent)] hover:opacity-90 transition-opacity">Browse Packages</a>
        <a href="https://github.com/ezequielgk/Kore-Recipes" class="px-6 py-2 font-medium text-[var(--text-secondary)] border border-[var(--border)] hover:bg-[var(--bg-hover)] transition-colors" target="_blank">GitHub</a>
      </div>
    </div>
  </section>

  <!-- FEATURED: renderizado client-side para random -->
  <section class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="text-xl font-semibold mb-6 pl-4 border-l-2 border-[var(--accent)] text-[var(--text-primary)]">Featured</h2>
    <div id="featured-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- JS lo llena en cada visita -->
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="max-w-7xl mx-auto px-4 py-12 pt-0">
    <h2 class="text-xl font-semibold mb-6 pl-4 border-l-2 border-[var(--border)] text-[var(--text-primary)]">Categories</h2>
    <div class="flex flex-wrap gap-4">
      {categories.map((cat: any) => (
        <a href={`/browse?category=${cat.name}`} class="inline-flex items-center gap-2 px-3 py-1.5 text-sm transition-colors bg-[var(--bg-secondary)] border border-[var(--border)] text-[var(--text-primary)] hover:border-[var(--accent)]">
          {cat.name}
          <span class="text-xs text-[var(--text-muted)]">{cat.count}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- DOCUMENTATION -->
  <section class="max-w-7xl mx-auto px-4 py-12 pt-0">
    <h2 class="text-xl font-semibold mb-6 pl-4 border-l-2 border-[var(--official)] text-[var(--text-primary)]">Documentation</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Instalar KPM -->
      <div class="bg-[var(--bg-card)] p-6" style="border: 1px solid var(--border);">
        <h3 class="text-lg font-medium mb-3 text-[var(--text-primary)]">How to install KPM</h3>
        <p class="text-sm text-[var(--text-secondary)] mb-4">KPM (Kore Package Manager) is the official CLI to install and manage all these applications.</p>
        <div class="relative group mb-4">
          <pre class="p-4 pr-16 overflow-x-auto text-sm" style="background: #0d0d0d; border: 1px solid var(--border); color: var(--accent); font-family: monospace;"><code>$ curl -sSL https://raw.githubusercontent.com/ezequielgk/Kore-Package-Manager/main/install.sh | bash</code></pre>
          <button class="copy-btn absolute top-2 right-2 px-2 py-1 text-xs opacity-0 group-hover:opacity-100 transition-opacity" style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-muted);" data-cmd="curl -sSL https://raw.githubusercontent.com/ezequielgk/Kore-Package-Manager/main/install.sh | bash">Copy</button>
        </div>
        <a href="https://github.com/ezequielgk/Kore-Package-Manager" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium transition-colors hover:bg-[var(--bg-hover)]" style="background: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border);">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path></svg>
          View on GitHub
        </a>
      </div>

      <!-- Desinstalar Standalone -->
      <div class="bg-[var(--bg-card)] p-6" style="border: 1px solid var(--border);">
        <h3 class="text-lg font-medium mb-3 text-[var(--text-primary)]">How to uninstall standalone apps</h3>
        <p class="text-sm text-[var(--text-secondary)] mb-4">If you installed an app without KPM (using the standalone script), you can remove it by deleting its files:</p>
        
        <div class="relative group mb-3">
          <pre class="p-4 pr-16 overflow-x-auto text-sm" style="background: #0d0d0d; border: 1px solid var(--border); color: var(--accent); font-family: monospace;"><code>$ rm -rf ~/.local/share/kpm/install/&lt;app_name&gt;</code></pre>
          <button class="copy-btn absolute top-2 right-2 px-2 py-1 text-xs opacity-0 group-hover:opacity-100 transition-opacity" style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-muted);" data-cmd="rm -rf ~/.local/share/kpm/install/<app_name>">Copy</button>
        </div>
        
        <div class="relative group">
          <pre class="p-4 pr-16 overflow-x-auto text-sm" style="background: #0d0d0d; border: 1px solid var(--border); color: var(--accent); font-family: monospace;"><code>$ rm ~/.local/bin/&lt;app_name&gt;</code></pre>
          <button class="copy-btn absolute top-2 right-2 px-2 py-1 text-xs opacity-0 group-hover:opacity-100 transition-opacity" style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-muted);" data-cmd="rm ~/.local/bin/<app_name>">Copy</button>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTALL EXTERNAL APPS (STANDALONE) -->
  <section class="max-w-7xl mx-auto px-4 py-16 pt-8">
    <div class="relative overflow-hidden bg-[var(--bg-card)] border border-[var(--border)] p-8 md:p-12" style="border-radius: 24px;">
      <!-- Decoración de fondo -->
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-[var(--accent)] rounded-full mix-blend-screen filter blur-[100px] opacity-20 pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col lg:flex-row gap-10 items-center">
        <div class="flex-1">
          <h2 class="text-3xl md:text-4xl font-bold mb-5 text-[var(--text-primary)] leading-tight">
            Go beyond KPM. <br />
            <span style="color: var(--accent);">Install any GitHub release.</span>
          </h2>
          <p class="text-[var(--text-secondary)] mb-6 text-lg max-w-xl leading-relaxed">
            Use our blazing fast standalone installer to fetch, extract, and install binaries from any public GitHub repository, even if they aren't listed in our registry.
          </p>
          <div class="flex flex-wrap gap-3 mb-4">
            <span class="px-3 py-1.5 text-xs font-medium bg-[var(--bg-secondary)] border border-[var(--border)] text-[var(--text-secondary)] rounded-full flex items-center gap-2">
              <svg class="w-3 h-3 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              Zero Dependencies
            </span>
            <span class="px-3 py-1.5 text-xs font-medium bg-[var(--bg-secondary)] border border-[var(--border)] text-[var(--text-secondary)] rounded-full flex items-center gap-2">
              <svg class="w-3 h-3 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              Auto-detects Architecture
            </span>
            <span class="px-3 py-1.5 text-xs font-medium bg-[var(--bg-secondary)] border border-[var(--border)] text-[var(--text-secondary)] rounded-full flex items-center gap-2">
              <svg class="w-3 h-3 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              Desktop Entry Support
            </span>
          </div>
        </div>
        
        <div class="flex-1 w-full relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-[var(--accent)] to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-300"></div>
          <div class="relative bg-[#09090b] border border-[var(--border)] rounded-xl p-6 w-full shadow-2xl">
            <div class="flex gap-2 mb-5 border-b border-gray-800 pb-4">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <pre class="overflow-x-auto text-sm md:text-base leading-relaxed whitespace-pre-wrap break-all" style="color: #e2e8f0; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;"><code><span style="color: #f472b6;">curl</span> -fsSL https://raw.githubusercontent.com/ezequielgk/kore.sh/main/public/get | <span style="color: #4ade80;">bash</span> -s -- --pkg <span style="color: #fde047;">"&lt;name&gt;"</span> --url <span style="color: #fde047;">"https://github.com/&lt;user&gt;/&lt;repo&gt;"</span> --format <span style="color: #fde047;">"tarball"</span></code></pre>
            <button class="copy-btn absolute top-5 right-5 px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded transition-colors backdrop-blur-md border border-white/10" data-cmd='curl -fsSL https://raw.githubusercontent.com/ezequielgk/kore.sh/main/public/get | bash -s -- --pkg "<name>" --url "https://github.com/<user>/<repo>" --format "tarball"'>
              Copy
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const dataEl = document.getElementById('pkg-data');
    if (!dataEl) return;
    
    const pkgs = JSON.parse(dataEl.textContent || '[]');
    const withIcon = pkgs.filter((p: any) => p.icon_url && p.origin === 'official');
    const shuffled = withIcon.sort(() => Math.random() - 0.5).slice(0, 6);
    
    const grid = document.getElementById('featured-grid');
    if (grid) {
      grid.innerHTML = shuffled.map((p: any) => {
        const originColor = p.origin === 'official' ? 'var(--official)' : 'var(--community)';
        return `
          <a href="/packages/${p.slug}" class="block h-full transition-colors duration-200 bg-[var(--bg-card)] p-4" style="border: 1px solid var(--border);" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
            <div class="flex items-start gap-4 mb-3">
               <div class="flex-shrink-0 flex items-center justify-center overflow-hidden">
                 <img src="${p.icon_url}" 
                     onerror="this.src='/icon/kore-pkg.svg'"
                     width="36" height="36" alt="${p.name}" class="app-icon" style="width: 36px; height: 36px;" loading="lazy" />
              </div>
              <div class="flex-grow min-w-0">
                <div class="flex flex-col">
                  <span class="text-base font-semibold truncate m-0 text-[var(--text-primary)]" title="${p.name}">${p.name}</span>
                  <span class="text-xs uppercase font-medium mt-1" style="color: ${originColor};">${p.origin}</span>
                </div>
              </div>
            </div>
            <p class="text-sm line-clamp-2 mt-2 text-[var(--text-secondary)] min-h-[2.5rem]">
              ${(p.description || '').slice(0, 80)}…
            </p>
          </a>
        `;
      }).join('');
    }

    // Copy logic
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const button = e.currentTarget as HTMLButtonElement;
        const cmd = button.getAttribute('data-cmd');
        if (cmd) {
          try {
            await navigator.clipboard.writeText(cmd);
            const originalHTML = button.innerHTML;
            button.innerHTML = 'Copied!';
            button.style.color = 'var(--accent)';
            button.style.borderColor = 'var(--accent)';
            setTimeout(() => {
              button.innerHTML = originalHTML;
              button.style.color = 'var(--text-muted)';
              button.style.borderColor = 'var(--border)';
            }, 2000);
          } catch (err) {
            console.error('Failed to copy text: ', err);
          }
        }
      });
    });
  });
</script>

<!-- Data embebida para el script cliente -->
<script id="pkg-data" type="application/json" set:html={JSON.stringify(packages)} />

---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found - Kore">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <img src="/v4/icon/kore-logo.svg" alt="Kore Logo" width="120" height="120" class="mb-8 opacity-50" />
    <h1 class="text-4xl font-bold mb-4">Page not found</h1>
    <p class="text-[var(--text-secondary)] mb-8 max-w-md">Sorry, we couldn't find the page or package you were looking for.</p>
    <a href="/v4/" class="inline-flex items-center justify-center px-6 py-3 font-semibold transition-colors" style="background: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border);">
      Go home
    </a>
  </div>
</Layout>

---
export interface Props {
  screenshots: string[];
}
const { screenshots } = Astro.props;
---

{screenshots.length > 0 && (
  <div class="my-8">
    <h2 class="text-xl font-bold text-white mb-4">Screenshots</h2>
    <div class="flex overflow-x-auto gap-4 snap-x snap-mandatory pb-4 custom-scrollbar">
      {screenshots.map((url) => (
        <div class="snap-center shrink-0 w-[85%] sm:w-[60%] md:w-[45%]">
          <img 
            src={url} 
            alt="App screenshot" 
            class="rounded-xl border border-gray-800 object-cover w-full shadow-lg"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .custom-scrollbar::-webkit-scrollbar {
    height: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #0f0f0f;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #374151;
    border-radius: 10px;
  }
</style>

#!/usr/bin/env bash
set -euo pipefail

# Parsear args
PKG="" URL="" FORMAT="tarball"
while [[ $# -gt 0 ]]; do
  case $1 in
    --pkg)    PKG="$2";    shift 2 ;;
    --url)    URL="$2";    shift 2 ;;
    --format) FORMAT="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$PKG" ] || [ -z "$URL" ]; then
  echo "Uso: curl -fsSL <url>/get | sh -s -- --pkg <name> --url <url> --format <fmt>"
  exit 1
fi

ARCH="$(uname -m)"
KPM_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/kpm"
KPM_BIN="${HOME}/.local/bin"
TMP_DIR="$(mktemp -d)"
cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT

echo "â†’ Instalando '$PKG'..."

# Resolver URL de descarga
DOWNLOAD_URL=""

# Si es AppImage directo
if [ "$FORMAT" = "appimage" ] && \
   ! echo "$URL" | grep -q "github.com/[^/]*/[^/]*$"; then
  DOWNLOAD_URL="$URL"
fi

# Si es GitHub repo, usar API
if [ -z "$DOWNLOAD_URL" ] && \
   echo "$URL" | grep -qE "^https://github\.com/[^/]+/[^/]+$"; then
  
  REPO="$(echo "$URL" | sed 's|https://github.com/||')"
  
  AUTH_HEADER=""
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    AUTH_HEADER="-H \"Authorization: Bearer $GITHUB_TOKEN\""
  fi
  
  echo "â†’ Consultando GitHub releases para $REPO..."
  
  API_RESP="$(curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    ${GITHUB_TOKEN:+-H "Authorization: Bearer $GITHUB_TOKEN"} \
    "https://api.github.com/repos/$REPO/releases/latest" \
    2>/dev/null || echo '{}')"
  
  # Detectar rate limit
  if echo "$API_RESP" | grep -q "rate limit\|API rate"; then
    echo "âś— GitHub API rate limit. ConfigurĂˇ: export GITHUB_TOKEN=tu_token"
    exit 1
  fi
  
  # Detectar repo no encontrado
  if echo "$API_RESP" | grep -q '"Not Found"'; then
    echo "âś— Repositorio no encontrado: $REPO"
    exit 1
  fi
  
  # Extraer URL del asset compatible
  DOWNLOAD_URL="$(echo "$API_RESP" \
    | grep '"browser_download_url"' \
    | grep -iE "linux.*(x86_64|amd64|x64)|x86_64.*linux|amd64" \
    | grep -ivE "\.sig$|\.sha256$|\.asc$|\.txt$|musl|arm|aarch64" \
    | head -1 \
    | sed 's/.*": "\(.*\)".*/\1/')"
  
  # Si no encontrĂł asset, intentar con tag + nombre del paquete
  if [ -z "$DOWNLOAD_URL" ]; then
    TAG="$(echo "$API_RESP" | grep '"tag_name"' \
      | head -1 | sed 's/.*": "\(.*\)".*/\1/')"
    echo "âš  No se encontrĂł asset automĂˇtico."
    if [ -n "$TAG" ]; then
      echo "  Ăšltima release: $TAG"
      echo "  RevisĂˇ manualmente: https://github.com/$REPO/releases"
    fi
    exit 1
  fi
fi

# Si URL directa (no GitHub repo raĂ­z)
if [ -z "$DOWNLOAD_URL" ]; then
  DOWNLOAD_URL="$URL"
fi

echo "â†’ Descargando: $(basename "$DOWNLOAD_URL")..."
FILENAME="$(basename "$DOWNLOAD_URL" | cut -d'?' -f1)"
curl -fsSL -L --progress-bar \
  "$DOWNLOAD_URL" -o "$TMP_DIR/$FILENAME"

# Verificar que se descargĂł algo
if [ ! -s "$TMP_DIR/$FILENAME" ]; then
  echo "âś— Descarga fallida o archivo vacĂ­o."
  exit 1
fi

# Extraer
mkdir -p "$TMP_DIR/extracted"
case "$FILENAME" in
  *.tar.gz|*.tgz)
    tar -xzf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.tar.xz)
    tar -xJf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.tar.bz2)
    tar -xjf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.zip)
    unzip -q "$TMP_DIR/$FILENAME" -d "$TMP_DIR/extracted" ;;
  *.AppImage)
    mkdir -p "$KPM_DATA/install/$PKG"
    cp "$TMP_DIR/$FILENAME" \
       "$KPM_DATA/install/$PKG/$PKG.AppImage"
    chmod +x "$KPM_DATA/install/$PKG/$PKG.AppImage"
    mkdir -p "$KPM_BIN"
    ln -sf "$KPM_DATA/install/$PKG/$PKG.AppImage" \
           "$KPM_BIN/$PKG"
    echo "âś“ $PKG instalado â†’ $KPM_BIN/$PKG"
    exit 0 ;;
  *)
    # Intentar como tarball genĂ©rico
    tar -xf "$TMP_DIR/$FILENAME" \
        -C "$TMP_DIR/extracted" 2>/dev/null || {
      echo "âś— Formato no reconocido: $FILENAME"
      exit 1
    } ;;
esac

# Encontrar ejecutable principal
EXEC="$(find "$TMP_DIR/extracted" -type f -executable \
  | grep -ivE "\.so(\.[0-9]+)*$|\.png$|\.svg$|\.desktop$|\.py$" \
  | head -1)"

if [ -z "$EXEC" ]; then
  echo "âś— No se encontrĂł ejecutable en el paquete."
  exit 1
fi

# Instalar
mkdir -p "$KPM_DATA/install/$PKG"
cp -r "$TMP_DIR/extracted/." "$KPM_DATA/install/$PKG/"
chmod +x "$KPM_DATA/install/$PKG/$(basename "$EXEC")"
mkdir -p "$KPM_BIN"
ln -sf "$KPM_DATA/install/$PKG/$(basename "$EXEC")" \
       "$KPM_BIN/$PKG"

# Avisar sobre PATH
if ! echo ":$PATH:" | grep -q ":$KPM_BIN:"; then
  echo ""
  echo "âš  AgregĂˇ a tu ~/.bashrc o ~/.zshrc:"
  echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
fi

echo ""
echo "âś“ $PKG instalado exitosamente."
echo "  EjecutĂˇ: $PKG"
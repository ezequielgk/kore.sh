#!/usr/bin/env bash
set -euo pipefail

PKG=""
URL=""
FORMAT=""

# Parse arguments
while [ "$#" -gt 0 ]; do
  case $1 in
    --pkg) PKG="$2"; shift ;;
    --url) URL="$2"; shift ;;
    --format) FORMAT="$2"; shift ;;
    *) echo "Unknown parameter passed: $1"; exit 1 ;;
  esac
  shift
done

if [ -z "$PKG" ] || [ -z "$URL" ] || [ -z "$FORMAT" ]; then
  echo "Uso: curl -fsSL https://kore-sh.vercel.app/get | bash -s -- --pkg <package_name> --url <url> --format <format>"
  exit 1
fi

ARCH="$(uname -m)"
OS="$(uname -s)"
KPM_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/kpm"
KPM_BIN="${HOME}/.local/bin"
TMP_DIR="$(mktemp -d)"

cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT

# ---------------------------------------------------------
# Interactive Menu Function (reads from /dev/tty)
# ---------------------------------------------------------
choose_menu() {
  local prompt="$1"
  shift
  local options=("$@")
  local selected=0
  local key

  printf "\n\033[0;36m%b\033[0m\n" "$prompt" >/dev/tty
  printf "\033[s" >/dev/tty

  while true; do
    printf "\033[u" >/dev/tty
    for i in "${!options[@]}"; do
      if [ "$i" -eq "$selected" ]; then
        printf "\033[36m> %s\033[0m\n" "${options[$i]}" >/dev/tty
      else
        printf "  %s\n" "${options[$i]}" >/dev/tty
      fi
    done

    # Read key from /dev/tty
    read -rsn1 key < /dev/tty || true
    if [[ $key == $'\x1b' ]]; then
      read -rsn2 key < /dev/tty || true
      if [[ $key == '[A' ]]; then
        ((selected--))
        [ "$selected" -lt 0 ] && selected=$((${#options[@]} - 1))
      elif [[ $key == '[B' ]]; then
        ((selected++))
        [ "$selected" -ge ${#options[@]} ] && selected=0
      fi
    elif [[ $key == "" ]]; then
      break
    fi
  done
  printf "\n" >/dev/tty
  echo "$selected"
}
# ---------------------------------------------------------

echo "→ Instalando '$PKG' via Kore Catalog..."

# 3. Si es GitHub, resolver la última release via API
if echo "$URL" | grep -q "github.com"; then
  REPO="$(echo "$URL" | sed 's|https://github.com/||' | sed 's|/$||')"
  
  # Fetch all assets
  API_RESPONSE="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest")"
  
  # Extract assets matching basic linux terms
  ASSETS=$(echo "$API_RESPONSE" \
    | grep '"browser_download_url"' \
    | grep -i "linux\|x86_64\|$ARCH\|\.AppImage" \
    | grep -v "\.sig\|\.sha\|\.asc\|\.rpm\|\.deb" \
    | sed 's/.*": "\(.*\)".*/\1/' || true)

  if [ -z "$ASSETS" ]; then
    echo "✗ No se encontraron assets compatibles para Linux."
    exit 1
  fi

  # Convert ASSETS string to array
  mapfile -t ASSET_ARRAY <<< "$ASSETS"
  
  if [ "${#ASSET_ARRAY[@]}" -eq 1 ]; then
    DOWNLOAD_URL="${ASSET_ARRAY[0]}"
  else
    # Ask the user which asset to download
    asset_names=()
    for a in "${ASSET_ARRAY[@]}"; do
      asset_names+=("$(basename "$a")")
    done
    
    idx=$(choose_menu "Múltiples assets encontrados. Selecciona el que deseas descargar:" "${asset_names[@]}")
    DOWNLOAD_URL="${ASSET_ARRAY[$idx]}"
  fi

else
  DOWNLOAD_URL="$URL"
fi

# 4. Descargar
echo "→ Descargando desde $DOWNLOAD_URL..."
FILENAME="$(basename "$DOWNLOAD_URL")"
curl -fsSL --progress-bar "$DOWNLOAD_URL" -o "$TMP_DIR/$FILENAME"

# 5. Extraer según formato
mkdir -p "$TMP_DIR/extracted"
case "$FILENAME" in
  *.tar.gz|*.tgz) tar -xzf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.tar.xz)       tar -xJf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.tar.bz2)      tar -xjf "$TMP_DIR/$FILENAME" -C "$TMP_DIR/extracted" ;;
  *.zip)          unzip -q "$TMP_DIR/$FILENAME" -d "$TMP_DIR/extracted" ;;
  *.AppImage)
    mkdir -p "$KPM_DATA/install/$PKG"
    cp "$TMP_DIR/$FILENAME" "$KPM_DATA/install/$PKG/$PKG.AppImage"
    chmod +x "$KPM_DATA/install/$PKG/$PKG.AppImage"
    mkdir -p "$KPM_BIN"
    ln -sf "$KPM_DATA/install/$PKG/$PKG.AppImage" "$KPM_BIN/$PKG"
    echo "✓ $PKG instalado. Ejecutá: $PKG"
    exit 0
    ;;
  *) 
    cp "$TMP_DIR/$FILENAME" "$TMP_DIR/extracted/$PKG"
    ;;
esac

# 6. Encontrar ejecutable principal
mapfile -t EXECS < <(find "$TMP_DIR/extracted" -type f -executable | grep -v "\.so\|\.png\|\.svg\|\.desktop" || true)

if [ "${#EXECS[@]}" -eq 0 ]; then
  # Try again without executable flag
  mapfile -t EXECS < <(find "$TMP_DIR/extracted" -type f | grep -v "\.so\|\.png\|\.svg\|\.desktop" || true)
  if [ "${#EXECS[@]}" -eq 0 ]; then
    echo "✗ No se encontró ejecutable en el paquete."
    exit 1
  fi
fi

if [ "${#EXECS[@]}" -eq 1 ]; then
  EXEC="${EXECS[0]}"
else
  # Ask the user which executable to link
  exec_names=()
  for e in "${EXECS[@]}"; do
    exec_names+=("$(basename "$e")")
  done
  
  idx=$(choose_menu "Múltiples ejecutables encontrados. Selecciona el principal:" "${exec_names[@]}")
  EXEC="${EXECS[$idx]}"
fi

# 7. Instalar
mkdir -p "$KPM_DATA/install/$PKG"
cp -r "$TMP_DIR/extracted/." "$KPM_DATA/install/$PKG/"

REL_EXEC="${EXEC#$TMP_DIR/extracted/}"

chmod +x "$KPM_DATA/install/$PKG/$REL_EXEC"
mkdir -p "$KPM_BIN"
ln -sf "$KPM_DATA/install/$PKG/$REL_EXEC" "$KPM_BIN/$PKG"

# 8. Agregar ~/.local/bin al PATH si no está
if ! echo "$PATH" | grep -q "$KPM_BIN"; then
  echo ""
  echo "⚠ Agregá esto a tu ~/.bashrc o ~/.zshrc:"
  echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
fi

echo ""
echo "✓ $PKG instalado exitosamente."
echo "  Ejecutá: $PKG"
